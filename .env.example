# ── SupplyGuard AI — Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# ── API Keys (for FastAPI REST endpoints) ─────────────────────────
API_KEY_ADMIN=generate-a-secure-random-key-here
API_KEY_ANALYST=generate-a-secure-random-key-here
API_KEY_VIEWER=generate-a-secure-random-key-here

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012
ECR_REPO=supplyguard-ai
ECS_CLUSTER=supplyguard-cluster
ECS_SERVICE=supplyguard-service

# ── CORS (comma-separated allowed origins) ────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
